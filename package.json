{
  "name": "winette",
  "version": "0.1.0",
  "description": "AI-powered wine label designer",
  "type": "module",
  "imports": {
    "#components/*": "./src/frontend/components/*",
    "#types/*": "./src/frontend/types/*",
    "#utils/*": "./src/frontend/utils/*",
    "#hooks/*": "./src/frontend/hooks/*",
    "#styles/*": "./src/frontend/styles/*",
    "#i18n/*": "./src/frontend/i18n/*"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch src/backend/index.ts",
    "build": "pnpm build:types && tsc && vite build && cp -r public/locales dist/",
    "build:types": "tsx scripts/generate-api-types.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "vanilla-extract": "vanilla-extract --watch",
    "prepare": "husky",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix"
  },
  "dependencies": {
    "@newrelic/browser-agent": "1.294.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "5.83.0",
    "@upstash/redis": "^1.28.2",
    "@vanilla-extract/css": "1.17.4",
    "@vanilla-extract/dynamic": "2.1.2",
    "@vanilla-extract/sprinkles": "1.6.3",
    "cors": "^2.8.5",
    "dotenv": "17.2.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "i18next": "^24.0.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "3.0.2",
    "newrelic": "12.6.0",
    "openapi-types": "^12.1.3",
    "openapi-typescript": "^6.7.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "4.1.2",
    "react-i18next": "^15.0.0",
    "zod": "^3.22.4",
    "zod-openapi": "^2.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@storybook/react": "9.0.17",
    "@storybook/react-vite": "9.0.17",
    "@tanstack/react-query-devtools": "5.83.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.0.5",
    "@vanilla-extract/vite-plugin": "4.0.18",
    "@vitejs/plugin-react": "4.4.1",
    "@vitest/ui": "3.2.4",
    "concurrently": "^8.2.2",
    "husky": "9.1.7",
    "jsdom": "25.0.1",
    "lint-staged": "16.1.2",
    "markdownlint-cli2": "0.18.1",
    "msw": "2.10.4",
    "msw-storybook-addon": "2.0.5",
    "storybook": "9.0.17",
    "tsx": "^4.7.0",
    "typescript": "5.7.3",
    "vite": "7.0.5",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write",
      "bash -c 'pnpm type-check'"
    ],
    "*.{js,jsx}": [
      "biome check --write"
    ],
    "*.{json,css}": [
      "biome format --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix --"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
